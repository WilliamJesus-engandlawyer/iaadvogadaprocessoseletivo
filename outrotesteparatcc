def chunking_hierarquico(texto: str) -> list[dict]:
    """
    Divide o texto respeitando a hierarquia artigo → parágrafo → inciso.
    Retorna lista de {cabecalho, text, artigo}.
    """
    delimitador = re.compile(
        r"(Art\.?\s*\d+[º°]?[.\-]?|"      
        r"§\s*\d+[º°]?[.\-]?|"            
        r"Parágrafo único\.?|"            
        r"[IVXLCDM]{1,6}\s*[-–]\s*)",     
        flags=re.I
    )

    partes = delimitador.split(texto)
    resultado = []
    artigo_atual = "Preâmbulo"

    i = 1
    while i < len(partes):
        cabecalho_raw = partes[i].strip() if i < len(partes) else ""
        conteudo_raw  = partes[i + 1].strip() if i + 1 < len(partes) else ""

        if not conteudo_raw:
            i += 2
            continue

        cabecalho = re.sub(r"\s+", " ", cabecalho_raw)

        if re.match(r"art\.?\s*\d+", cabecalho, re.I):
            artigo_atual = cabecalho

        chunk_texto = (cabecalho + " " + conteudo_raw)[:CHUNK_MAX_CHARS]

        if len(chunk_texto) >= CHUNK_MIN_CHARS:
            resultado.append({
                "cabecalho": cabecalho[:200],
                "text":      chunk_texto,  # Padronizado para 'text'
                "artigo":    artigo_atual[:120],
            })
        i += 2

    if len(resultado) < 3:
        resultado = sliding_window(texto)

    return resultado

def sliding_window(texto: str, tamanho: int = 1500, sobreposicao: int = 300) -> list[dict]:
    chunks_sw = []
    inicio = 0
    while inicio < len(texto):
        fim = min(inicio + tamanho, len(texto))
        trecho = texto[inicio:fim].strip()
        if len(trecho) >= CHUNK_MIN_CHARS:
            chunks_sw.append({
                "cabecalho": f"Trecho ~{inicio//1000}k",
                "text":      trecho,       # Padronizado para 'text'
                "artigo":    "Sem estrutura",
            })
        inicio += tamanho - sobreposicao
    return chunks_sw

def extrai_artigos_incisos_v2(texto: str) -> list[dict]:
    return chunking_hierarquico(texto)

def limpa_texto(texto: str) -> str:
    """Remove artefatos comuns de PDF."""
    texto = re.sub(r"(?<!\n)\n(?!\n)", " ", texto)
    texto = re.sub(r" {2,}", " ", texto)
    texto = re.sub(r"\f", "\n\n", texto)
    return texto.strip()

def extrai_norma(texto: str, nome_arquivo: str) -> str:
    """Tenta extrair identificação da norma no cabeçalho do PDF."""
    padrao = r"(lei\s+(?:complementar\s+)?|decreto(?:\s*-lei)?\s+|lc\s+)n?[º°]?\s*([\d.]+)\s*[,/de]+\s*(\d{4})"
    m = re.search(padrao, texto[:3000], re.I)
    if m:
        return m.group(0).upper().strip()
    return Path(nome_arquivo).stem.replace("_", " ").replace("-", " ").title()

