# CÉLULA 5 — Busca híbrida com reranking
# ============================================================

def busca(
    pergunta_texto: str,
    top_k_vec: int = 40,     # candidatos da busca vetorial
    top_k_final: int = 12,   # após fusão híbrida
    top_k_rerank: int = 6,   # após reranking
    verbose: bool = True,
) -> list[dict]:
    """
    Pipeline completo:
      1. k-NN vetorial  (semântica)
      2. BM25 sobre os candidatos (palavras-chave)
      3. Fusão ponderada dos scores
      4. Cross-encoder reranking (precisão máxima)
    """
    # 1 ── Embedding da pergunta
    query_vec = embed_model.encode(
        pergunta_texto, normalize_embeddings=True
    ).tolist()

 # 2 ── Busca vetorial
candidatos = (
    tbl.search(query_vec, vector_column_name="vector")
       .limit(top_k_vec)
       .to_list()
)

if "lei 9.784" in pergunta_texto.lower():
    filtrados = [c for c in candidatos if "9.784" in c["text"]]
    if filtrados:
        candidatos = filtrados

if not candidatos:
    print("⚠️  Nenhum resultado encontrado.")
    return []

    # 3 ── BM25 sobre os candidatos
    corpus_tok = [doc["text"].lower().split() for doc in candidatos]
    bm25 = BM25Okapi(corpus_tok)
    bm25_scores = bm25.get_scores(pergunta_texto.lower().split())

    # Normaliza BM25 para [0, 1]
    bm25_max = bm25_scores.max() or 1.0
    bm25_norm = bm25_scores / bm25_max

    # 4 ── Fusão híbrida
    for i, doc in enumerate(candidatos):
        sem_score = 1.0 - doc.get("_distance", 1.0)   # cosine → similaridade
        doc["score_hybrid"] = (VETOR_WEIGHT * sem_score) + (BM25_WEIGHT * bm25_norm[i])

    candidatos.sort(key=lambda x: x["score_hybrid"], reverse=True)
    candidatos = candidatos[:top_k_final]

    # 5 ── Cross-encoder reranking
    pairs = [[pergunta_texto, r["text"]] for r in candidatos]
    rerank_scores = reranker.predict(pairs, show_progress_bar=False)
    for i, r in enumerate(candidatos):
        r["rerank_score"] = float(rerank_scores[i])

    candidatos.sort(key=lambda x: x["rerank_score"], reverse=True)
    resultados = candidatos[:top_k_rerank]

    # 6 ── Exibição
    if verbose:
        print(f"\n{'═'*70}")
        print(f"  Pergunta: {pergunta_texto}")
        print(f"{'═'*70}")
        for i, r in enumerate(resultados, 1):
            fonte = r["source"] if r["source"] != "base_conceitos" else "Conceito jurídico"
            score = r["rerank_score"]
            artigo = r["artigo"][:70].strip()
            print(f"\n[{i}] {r['norma']} — {artigo}")
            print(f"     Fonte: {fonte}  |  Score: {score:.3f}")
            print(f"     {r['text'][:500]}{'...' if len(r['text']) > 500 else ''}")
            print(f"{'─'*70}")

    return resultados


